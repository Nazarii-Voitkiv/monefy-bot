{
  "name": "monefy-bot",
  "version": "1.0.0",
  "description": "Telegram bot for personal finance tracking with multi-currency support.",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint app src tests --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,json,md,css}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "test": "tsx --test tests/**/*.test.ts",
    "telegram:webhook:set": "node scripts/setTelegramWebhook.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nazarii-Voitkiv/monefy-bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "bugs": {
    "url": "https://github.com/Nazarii-Voitkiv/monefy-bot/issues"
  },
  "homepage": "https://github.com/Nazarii-Voitkiv/monefy-bot#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.76.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "next": "16.2.2",
    "node-cache": "^5.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
